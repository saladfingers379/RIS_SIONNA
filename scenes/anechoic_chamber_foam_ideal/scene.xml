<scene version="3.0.0">
  <integrator type="path">
    <integer name="max_depth" value="8"/>
  </integrator>

  <emitter type="constant">
    <rgb name="radiance" value="1.0"/>
  </emitter>

  <!-- Ideal chamber test scene: foam chamber assets, absorber floor, no stools. -->
