    <bsdf type="diffuse">
      <rgb name="reflectance" value="0.08"/>
    </bsdf>
  </bsdf>

  <!-- Absorber surfaces -->
  <shape type="ply" id="absorber_back">
    <string name="filename" value="../anechoic_chamber_foam/meshes/absorber_back.ply"/>
