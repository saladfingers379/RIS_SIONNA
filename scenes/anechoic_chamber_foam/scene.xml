<scene version="3.0.0">
  <integrator type="path">
    <integer name="max_depth" value="8"/>
  </integrator>

  <emitter type="constant">
    <rgb name="radiance" value="1.0"/>
  </emitter>

  <!-- Placeholder visual BSDFs.
       If your repo expects specific radio-material names, keep the mat-itu_* pattern
       and rename these ids to match whatever your loader/material mapping expects. -->

  <bsdf type="twosided" id="mat-itu_absorber">
    <bsdf type="diffuse">
      <rgb name="reflectance" value="0.08"/>
    </bsdf>
  </bsdf>

  <bsdf type="twosided" id="mat-itu_metal">
    <bsdf type="diffuse">
      <rgb name="reflectance" value="0.65"/>
    </bsdf>
  </bsdf>

  <bsdf type="twosided" id="mat-itu_wood">
    <bsdf type="diffuse">
      <rgb name="reflectance" value="0.45"/>
    </bsdf>
  </bsdf>

  <!-- Absorber surfaces -->
  <shape type="ply" id="absorber_back">
    <string name="filename" value="meshes/absorber_back.ply"/>
    <ref id="mat-itu_absorber" name="bsdf"/>
  </shape>

  <shape type="ply" id="absorber_floorbar">
    <string name="filename" value="meshes/absorber_floorbar.ply"/>
